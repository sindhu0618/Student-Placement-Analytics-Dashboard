            <run>Æ&#10;</run>
            <run bold='true' fontname='Benton Sans Book' fontsize='18'>Æ                </run>
            <run>Æ&#10;</run>
            <run bold='true' fontname='Benton Sans Book' fontsize='18'>                8.3</run>
