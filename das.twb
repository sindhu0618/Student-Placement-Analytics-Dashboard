    <worksheet name='certification impact'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='16'>Certification Performance Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Student_Placement_Analytics_1000' name='federated.0who71j1g86yio13sddhn05ctacm' />
          </datasources>
          <datasource-dependencies datasource='federated.0who71j1g86yio13sddhn05ctacm'>
            <column caption='Aptitude Score' datatype='integer' name='[Aptitude_Score]' role='measure' type='quantitative' />
            <column caption='Cgpa' datatype='real' default-format='p0%' name='[CGPA]' role='measure' type='quantitative' />
            <column caption='Placement Prediction' datatype='string' name='[Calculation_0768023188803584]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CGPA] &gt;= 8 AND [Aptitude_Score] &gt;= 80 AND [Internships] &gt;= 1 THEN &quot;High Chance&quot;&#13;&#10;&#13;&#10;ELSEIF [CGPA] &gt;= 7 AND [Aptitude_Score] &gt;= 70 THEN &quot;Medium Chance&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low Chance&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='CGPA Range' datatype='string' name='[Calculation_0768023192608769]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CGPA] &lt; 6 THEN &quot;Below 6&quot;&#13;&#10;ELSEIF [CGPA] &lt; 7 THEN &quot;6-7&quot;&#13;&#10;ELSEIF [CGPA] &lt; 8 THEN &quot;7-8&quot;&#13;&#10;ELSEIF [CGPA] &lt; 9 THEN &quot;8-9&quot;&#13;&#10;ELSE &quot;9+&quot;&#13;&#10;END' />
            </column>
            <column caption='Placement Flag' datatype='integer' default-format='p0%' name='[Calculation_1163845428858883]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Placement_Status] = &quot;Placed&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='Package Range Label' datatype='string' datatype-customized='true' name='[Calculation_1163845435494404]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  [CGPA] &gt;= 9 THEN &quot;12+ LPA&quot;&#13;&#10;&#13;&#10;ELSEIF [CGPA] &gt;= 8 THEN &quot;8-12 LPA&quot;&#13;&#10;&#13;&#10;ELSEIF [CGPA] &gt;= 7 THEN &quot;5-8 LPA&quot;&#13;&#10;&#13;&#10;ELSE &quot;3-5 LPA&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Placement Rate' datatype='real' default-format='p0.0%' name='[Calculation_1286715679989760]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Placement_Status] = &quot;Placed&quot; THEN [Student_ID] END&#13;&#10;)&#13;&#10;/ COUNTD([Student_ID])' />
            </column>
            <column datatype='integer' name='[Certifications]' role='measure' type='ordinal' />
            <column datatype='integer' name='[Internships]' role='measure' type='ordinal' />
            <column caption='Placement Status' datatype='string' name='[Placement_Status]' role='dimension' type='nominal' />
            <column aggregation='None' caption='Projects (bin)' datatype='integer' name='[Projects (bin)]' role='dimension' type='ordinal'>
